/dkg-runner
/circuit-compile
/dkgcli
*.exe
*.test
*.out

# ---- Circuit artifacts ----------------------------------------------------
# Cached proving/verifying keys and constraint systems. Regenerated locally
# on first run via `make circuits-compile`.
/artifacts/
/tmp/

