# ---- Build output ---------------------------------------------------------
# Vite-produced bundle. Regenerated by `pnpm build` / `make ui-build`,
# baked into the standalone UI Docker image at build time.
dist/
.vite/

# ---- Dependencies ---------------------------------------------------------
node_modules/

# ---- Test / coverage ------------------------------------------------------
coverage/
*.lcov
.vitest-cache/

# ---- TypeScript -----------------------------------------------------------
*.tsbuildinfo

# ---- Local config overrides ----------------------------------------------
# public/config.json is committed with the published Sepolia defaults; a
# `make ui-dev RPC_URL=…` invocation rewrites it locally for ad-hoc dev.
# Don't ignore it outright (we want the published file tracked), but DO
# ignore developer-local overrides.
public/config.local.json

# ---- Logs / lockfile artefacts -------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---- Editor / OS ----------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---- Env / secrets --------------------------------------------------------
.env
.env.local
.env.*.local
