# ---------------------------------------------------------------------------
# davinci-dkg-node configuration
#
# Copy to .env and fill in the required values. Every entry is also
# settable as a CLI flag — run `davinci-dkg-node --help` for the full list.
# Env vars use the DAVINCI_DKG_ prefix and dots/dashes in flag names are
# translated to underscores, e.g. --web3.rpc → DAVINCI_DKG_WEB3_RPC,
# --poll-interval → DAVINCI_DKG_POLL_INTERVAL.
# ---------------------------------------------------------------------------

# ---- Chain connection -----------------------------------------------------
# JSON-RPC endpoint(s). Comma-separated if you want redundancy.
DAVINCI_DKG_WEB3_RPC=http://127.0.0.1:8545

# Hex private key used to sign node transactions (registration, claim,
# contribute, decrypt). Must start with 0x.
DAVINCI_DKG_PRIVKEY=

# ---- Network / contract addresses ----------------------------------------
# Set DAVINCI_DKG_NETWORK to a well-known network name to skip manual address
# configuration. The DKGManager address and all verifier contract addresses are
# resolved automatically. Currently supported: sepolia (alias: sep).
#
#   DAVINCI_DKG_NETWORK=sepolia
#
# Alternatively, set DAVINCI_DKG_MANAGER explicitly (required when deploying
# to a custom or unsupported network). Takes precedence over NETWORK.
DAVINCI_DKG_NETWORK=
DAVINCI_DKG_MANAGER=

# ---- Node runtime ---------------------------------------------------------
# Local state directory (keys, caches).
DAVINCI_DKG_DATADIR=

# How often the service polls the chain for round lifecycle events.
DAVINCI_DKG_POLL_INTERVAL=20s

# Shared directory for ciphertext files (testnet only).
DAVINCI_DKG_SHARED_DIR=/shared

# Circuit artifact cache directory. Defaults to ~/.davinci/artifacts when empty.
DAVINCI_DKG_ARTIFACTS_DIR=

# ---- Logging --------------------------------------------------------------
# Level: debug | info | warn | error
DAVINCI_DKG_LOG_LEVEL=info
DAVINCI_DKG_LOG_OUTPUT=stdout

# ---- Contract deployment (solidity/deploy_all.sh) ------------------------
# These are only read by the deployment script, not by the node.
# RPC_URL, CHAIN_ID and PRIVATE_KEY are required; ETHERSCAN_API_KEY is
# optional and unlocks post-deploy contract verification on Etherscan (or
# any Etherscan-compatible explorer, set VERIFIER_URL to point to it).
# RPC_URL=
# CHAIN_ID=
# PRIVATE_KEY=
# ETHERSCAN_API_KEY=
# VERIFIER_URL=

# ---- Docker Compose overrides (optional) ---------------------------------
# Pin the image tag used by the compose `node` service. Defaults to
# `latest`, which Watchtower will follow. Set to an immutable version
# (e.g. v0.1.0) to disable auto-updates for this deployment.
# DAVINCI_DKG_TAG=latest

# ---- Standalone UI image (compose `ui` profile, optional) ----------------
# Pin the standalone UI image tag and override the host-side port the
# nginx container listens on. The UI talks to the chain directly; see the
# header of docker-compose.yml for the full list of UI env knobs
# (DAVINCI_DKG_RPC_URL, DAVINCI_DKG_MANAGER_ADDRESS, …) plus their short
# RPC_URL / MANAGER_ADDRESS / … aliases.
# DAVINCI_DKG_UI_TAG=latest
# DAVINCI_DKG_UI_PORT=8082
